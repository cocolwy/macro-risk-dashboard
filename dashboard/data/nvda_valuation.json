    "intuition": "\u94b1\u5728\u4eca\u5929\u6bd4\u5728\u4e94\u5e74\u540e\u66f4\u503c\u94b1\uff1b\u98ce\u9669\u8d8a\u9ad8\uff08WACC \u8d8a\u9ad8\uff09\uff0c\u540c\u6837\u4e00\u7b14\u672a\u6765\u73b0\u91d1\u7684\u4eca\u5929\u51fa\u4ef7\u8d8a\u4f4e\u3002"
  }
